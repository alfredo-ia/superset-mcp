{
  "name": "alfredo-superset-mcp",
  "version": "0.0.2",
  "description": "MCP server for reading and editing Apache Superset dataset data",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "superset-mcp": "build/index.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc || \"%npm_node_execpath%\" ./node_modules/typescript/bin/tsc",
    "prepare": "node ./node_modules/typescript/bin/tsc || \"%npm_node_execpath%\" ./node_modules/typescript/bin/tsc",
    "dev": "node ./node_modules/typescript/bin/tsc --watch || \"%npm_node_execpath%\" ./node_modules/typescript/bin/tsc --watch",
    "start": "node build/index.js || \"%npm_node_execpath%\" build/index.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "node --test test/*.test.mjs || \"%npm_node_execpath%\" --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "axios": "^1.6.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "files": [
    "build",
    "README.md",
    "README_zh.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "superset",
    "dataset",
    "apache-superset",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/alfredo-ia/superset-mcp",
  "author": "Winding2020",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alfredo-ia/superset-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/alfredo-ia/superset-mcp/issues"
  }
}